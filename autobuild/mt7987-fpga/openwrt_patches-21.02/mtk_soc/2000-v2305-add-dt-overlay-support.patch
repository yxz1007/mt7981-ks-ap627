+			hash-1 {
+				algo = \"crc32\";
+			};
+			hash-2 {
+				algo = \"${HASH}\";
+			};
 		};
-	};
 "
+	INITRD_PROP="ramdisk=\"initrd${REFERENCE_CHAR}${INITRDNUM}\";"
 fi
 
-# Conditionally create script information
-if [ -n "${UBOOT_SCRIPT}" ]; then
